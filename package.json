{
    "name": "fastevent-repos",
    "version": "1.1.3",
    "description": "fast event emitter",
    "private": true,
    "access": "public",
    "homepage": "https://github.com/zhangfisher/fastevent.git",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/zhangfisher/fastevent.git"
    },
    "scripts": {
        "test": "vitest",
        "test:coverage": "vitest --coverage --exclude=\"src/__benchmarks__/**\"  --exclude=src/devTools",
        "build": "turbo build --filter=fastevent",
        "bench": "tsx src/__benchmarks__/index.ts",
        "update:changelog": "cpx packages/native/CHANGELOG.md docs/zh/guide/intro/",
        "changeset": "changeset",
        "publish-packages": "bun run build && changeset version && changeset publish",
        "only-publish-packages": "bun run build && npm publish",
        "release": "bun run build && bun run changeset version && cpx packages/native/CHANGELOG.md docs/zh/guide/intro/ && bun run changeset publish",
        "sync": "cnpm sync fastevent",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs"
    },
    "keywords": [
        "eventemitter"
    ],
    "author": "zhangfisher",
    "license": "MIT",
    "devDependencies": {
        "@changesets/cli": "^2.30.0",
        "@shikijs/vitepress-twoslash": "^4.0.2",
        "@types/bun": "^1.3.10",
        "@types/node": "^25.5.0",
        "cpx": "^1.5.0",
        "oxfmt": "^0.40.0",
        "oxlint": "^1.55.0",
        "oxlint-tsgolint": "^0.17.0",
        "turbo": "^2.8.17",
        "type-fest": "^5.4.4",
        "typescript": "^5.9.3",
        "vitepress": "^1.6.4"
    },
    "packageManager": "bun@1.3.10",
    "workspaces": [
        "packages/*",
        "docs"
    ]
}