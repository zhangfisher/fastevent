{
    "name": "fastevent",
    "version": "2.6.1",
    "private": false,
    "description": "The Ultimate Event Trigger Library – Fast, Feature-Rich, Battle-Tested!",
    "keywords": [
        "eventemitter",
        "events"
    ],
    "homepage": "https://zhangfisher.github.io/fastevent/",
    "license": "MIT",
    "author": "zhangfisher",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/zhangfisher/fastevent.git"
    },
    "workspaces": [
        "packages/*",
        "examples/*",
        "docs"
    ],
    "files": [
        "dist",
        "readme.md"
    ],
    "sideEffects": [
        "dist/viewer/*.js",
        "dist/viewer/*.mjs"
    ],
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./lite": {
            "types": "./dist/liteEvent.d.ts",
            "import": "./dist/liteEvent.mjs",
            "require": "./dist/liteEvent.js",
            "default": "./dist/liteEvent.js"
        },
        "./executors": {
            "types": "./dist/executors/index.d.ts",
            "import": "./dist/executors/index.mjs",
            "require": "./dist/executors/index.js"
        },
        "./pipes": {
            "types": "./dist/pipes/index.d.ts",
            "import": "./dist/pipes/index.mjs",
            "require": "./dist/pipes/index.js"
        },
        "./viewer": {
            "types": "./dist/viewer/fastevent.viewer.d.ts",
            "import": "./dist/viewer/index.mjs",
            "require": "./dist/viewer/index.js",
            "default": "./dist/viewer/index.js"
        },
        "./fastevent-viewer": "./dist/viewer/index.js"
    },
    "scripts": {
        "test": "bun test",
        "test:coverage": "vitest --coverage --exclude=\"src/__benchmarks__/**\"  --exclude=src/devTools",
        "build": "tsup && cpy \"./index.global.js\" ../../../docs/public  --cwd=./dist --rename=fastevent.js",
        "bench": "tsx src/__benchmarks__/index.ts"
    },
    "devDependencies": {
        "@changesets/cli": "^2.28.1",
        "@swc/core": "^1.15.18",
        "@type-challenges/utils": "^0.1.1",
        "@vitest/coverage-v8": "4.1.0",
        "cpx": "^1.5.0",
        "cpy-cli": "^7.0.0",
        "eventemitter2": "^6.4.9",
        "redux": "^5.0.1",
        "tinybench": "^6.0.0",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitepress": "^1.6.4",
        "vitest": "^4.1.0"
    },
    "packageManager": "bun@1.3.10",
    "access": "public"
}
